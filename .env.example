# Transporte: "stdio" (para uso local con Claude Code) o "http"
MCP_TRANSPORT=stdio
PORT=3000

# SurrealDB
SURREAL_URL=ws://localhost:8000
SURREAL_NS=personal
SURREAL_DB=memory
SURREAL_USER=root
SURREAL_PASS=root

# API key de Gemini (requerida para el servicio de embeddings)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-embedding-2-preview
EMBED_DIMENSIONS=1536
